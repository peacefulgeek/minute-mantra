# Database
DATABASE_URL=mysql://user:password@host:3306/minute_mantra

# Auth
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRY=7d

# Square (payment processing)
SQUARE_ACCESS_TOKEN=
SQUARE_ENVIRONMENT=production
SQUARE_WEBHOOK_SIGNATURE_KEY=
SQUARE_MONTHLY_PLAN_ID=
SQUARE_ANNUAL_PLAN_ID=

# VAPID (generate with: node scripts/generate-vapid.js)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:paul@paulwagner.com

# SMTP2GO HTTP API (for email delivery)
SMTP_API=your-smtp2go-api-key
SMTP_FROM_ADDRESS=paul@paulwagner.one
SMTP_FROM_NAME=Minute Mantra

# Bunny CDN
BUNNY_CDN_BASE_URL=https://minute-mantra.b-cdn.net
BUNNY_STORAGE_API_KEY=
BUNNY_STORAGE_ZONE_NAME=minute-mantra
BUNNY_STORAGE_HOST=ny.storage.bunnycdn.com

# App
APP_URL=https://minutemantra.com
NODE_ENV=production
PORT=3000
