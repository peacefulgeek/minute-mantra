{
  "name": "minute-mantra",
  "version": "1.0.0",
  "description": "Minute Mantra PWA — One mantra. One minute. Every morning.",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "cd client && pnpm install && pnpm build",
    "start": "NODE_ENV=production node index.js",
    "dev:server": "nodemon index.js",
    "dev:client": "cd client && pnpm dev",
    "seed": "node seeds/seed.js",
    "generate-vapid": "node scripts/generate-vapid.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.20.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.8",
    "square": "^33.0.0",
    "uuid": "^9.0.1",
    "web-push": "^3.6.6"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
